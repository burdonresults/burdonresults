<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Burdon Results</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<!-- TOP NAV -->
<header class="nav">
  <div class="logo">
    <img src="logo.png" alt="logo">
  </div>

  <nav class="nav-links">
    <a href="#services">Services</a>
    <a href="#about">About</a>
    <a href="#contact">Contact</a>
  </nav>

  <div class="login">Login</div>
</header>

<!-- HERO SECTION -->
<section class="hero">

  <!-- BACKGROUND IMAGE -->
  <div class="hero-image">
    <img src="image1.jpg" alt="hero image">
  </div>

  <!-- HERO TEXT -->
  <div class="hero-text">
    <h1>Results that, actually make a difference.</h1>
  </div>

  <!-- CURVE DIVIDER -->
  <div class="curve-divider"></div>
</section>

<!-- SERVICES SECTION -->
<section id="services" class="services">

  <h2>Services</h2>

  <p class="description">
    Finely hand crafted skills and expertise developed over years of professional practice.
  </p>

  <div class="service-list">

    <div class="service-item">
      <span>Marketing</span>
      <span class="plus">+</span>
    </div>

    <div class="service-item">
      <span>Graphic Design</span>
      <span class="plus">+</span>
    </div>

    <div class="service-item">
      <span>Analytics</span>
      <span class="plus">+</span>
    </div>

  </div>
</section>

<!-- MIDDLE SECTION -->
<section class="middle">

  <!-- VIDEO BLOCK -->
  <div class="video-box">
    <video controls>
      <source src="video.mp4" type="video/mp4">
    </video>
  </div>

  <!-- FORM BLOCK -->
  <div class="form-box">

    <input type="text" placeholder="Name">
    <input type="text" placeholder="Company Name">
    <input type="email" placeholder="Email">
    <input type="text" placeholder="Phone Number">
    <textarea placeholder="Request"></textarea>

    <button>Submit</button>

  </div>

</section>

<!-- BOTTOM BANNER IMAGE -->
<section class="bottom-banner">
  <img src="image2.jpg" alt="bottom banner">
</section>

<!-- FOOTER -->
<footer class="footer">

  <div class="footer-left">
    <img src="logo.png" alt="logo">
  </div>

  <div class="footer-links">
    <div>
      <a href="#">Privacy Policy</a>
      <a href="#">Terms & Conditions</a>
      <a href="#">Refund Policy</a>
    </div>

    <div>
      <a href="#">Services</a>
      <a href="#">About Us</a>
      <a href="#">Contact</a>
      <a href="#">FAQs</a>
    </div>
  </div>

  <div class="footer-contact">
    <p>Phone: 0750XXXXXXX</p>
    <p>Email: br@burdonresults.com</p>
  </div>

</footer>

</body>
</html>
